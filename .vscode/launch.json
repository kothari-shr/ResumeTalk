{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Streamlit (Launch)",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": ["run", "streamlit_app.py", "--server.port=8501"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "VIRTUAL_ENV": "${workspaceFolder}/.venv",
        "PATH": "${workspaceFolder}/.venv/bin:${env:PATH}"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Streamlit (Attach debugpy)",
      "type": "python",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "${workspaceFolder}"
        }
      ],
      "justMyCode": false
    }
  ]
}
